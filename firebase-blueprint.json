{
  "entities": {
    "Room": {
      "title": "Room",
      "description": "A game room hosted by a user for remote buzzer functionality.",
      "type": "object",
      "properties": {
        "hostId": { "type": "string", "description": "The UID of the host who created the room." },
        "gameState": { 
          "type": "string", 
          "enum": ["waiting", "playing", "question", "revealed"], 
          "description": "The current state of the game session." 
        },
        "buzzedPlayerId": { "type": ["string", "null"], "description": "The UID of the player who buzzed first in the current question." },
        "buzzedAt": { "type": ["string", "null"], "format": "date-time", "description": "ISO 8601 timestamp of when the buzz occurred." },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of room creation." }
      },
      "required": ["hostId", "gameState", "createdAt"]
    },
    "Player": {
      "title": "Player",
      "description": "A participant in a game room.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the player." },
        "color": { "type": "string", "description": "Hex color code for the player's avatar." },
        "score": { "type": "number", "description": "Current total score of the player." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of joining." }
      },
      "required": ["name", "color", "score", "joinedAt"]
    },
    "User": {
      "title": "User",
      "description": "Registered user profile.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name of the user." },
        "email": { "type": "string", "format": "email", "description": "Primary email address." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "Privilege level." },
        "createdAt": { "type": "string", "format": "date-time", "description": "ISO 8601 timestamp of account creation." }
      },
      "required": ["name", "email", "role", "createdAt"]
    },
    "VaultQuestion": {
      "title": "VaultQuestion",
      "description": "A quiz question stored in the user's personal vault for analysis and recycling.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier (usually {userId}_{originalId})." },
        "userId": { "type": "string", "description": "UID of the owner." },
        "text": { "type": "string", "description": "The question text." },
        "answer": { "type": "string", "description": "Correct answer text." },
        "category": { "type": "string", "description": "Broad category name." },
        "topic_match": { "type": "string", "description": "Lowercase topic for search indexing." },
        "points": { "type": "number", "description": "Base points for the question." },
        "difficulty": { "type": "string", "enum": ["EASY", "MEDIUM", "HARD"], "description": "Nominal difficulty level." },
        "type": { "type": "string", "enum": ["MCQ", "TRUE_FALSE", "OPEN"], "description": "Question format." },
        "mode": { "type": "string", "description": "Game mode this was generated for." },
        "times_played": { "type": "number", "description": "Total times this question has been presented." },
        "last_played_at": { "type": "number", "description": "Unix timestamp of last appearance." },
        "running_time_sum": { "type": "number", "description": "Sum of response times for averaging." },
        "correct_count": { "type": "number", "description": "Successful completions count." },
        "mastered": { "type": "boolean", "description": "Whether the user has demonstrated high proficiency." },
        "real_difficulty_score": { "type": "number", "description": "Dynamic difficulty based on speed/accuracy." },
        "updated_at": { "type": "number", "description": "Unix timestamp of last update." }
      },
      "required": ["id", "userId", "text", "answer", "topic_match"]
    },
    "SavedSet": {
      "title": "SavedSet",
      "description": "A collection of questions saved by a user for future games.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "topic": { "type": "string" },
        "numQuestions": { "type": "number" },
        "mode": { "type": "string" },
        "difficulty": { "type": "string" },
        "questions": { "type": "array" },
        "createdAt": { "type": "number" }
      },
      "required": ["id", "userId", "name", "topic"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Global user profiles."
    },
    "rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Active game sessions."
    },
    "rooms/{roomId}/players/{playerId}": {
      "schema": { "$ref": "#/entities/Player" },
      "description": "Sub-collection of players within a specific room."
    },
    "questions_vault/{questionId}": {
      "schema": { "$ref": "#/entities/VaultQuestion" },
      "description": "User-private question database."
    },
    "saved_sets/{setId}": {
      "schema": { "$ref": "#/entities/SavedSet" },
      "description": "User-private saved question sets."
    },
    "_connectivity_test_/{testId}": {
      "schema": { "type": "object", "properties": { "ping": { "type": "string" } } },
      "description": "Public path used for connection testing."
    }
  }
}
